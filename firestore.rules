rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Book Validations ---
    function isValidBook(data) {
      return data.keys().hasAll(['title', 'authorName', 'status', 'userId', 'createdAt', 'updatedAt'])
        && (data.title is string)
        && (data.authorName is string)
        && (data.status in ['want-to-read', 'reading', 'read', 'dnf'])
        && (data.userId == request.auth.uid)
        // Relaxing timestamp checks to prevent strict rejections
        && (data.createdAt <= request.time && data.updatedAt <= request.time)
        && (!('rating' in data) || (data.rating is number))
        && (!('liked' in data) || (data.liked is bool))
        && (!('notes' in data) || (data.notes is string))
        && (!('coverUrl' in data) || (data.coverUrl is string))
        && (!('backCoverUrl' in data) || (data.backCoverUrl is string))
        && (!('genre' in data) || (data.genre is string))
        && (!('series' in data) || (data.series is string))
        && (!('seriesPosition' in data) || (data.seriesPosition is string))
        && (!('isbn' in data) || (data.isbn is string))
        && (!('pages' in data) || (data.pages is number))
        && (!('boredomReason' in data) || (data.boredomReason is string));
    }

    function isValidBookUpdate(data) {
      return (!('title' in data) || (data.title is string))
        && (!('authorName' in data) || (data.authorName is string))
        && (!('status' in data) || (data.status in ['want-to-read', 'reading', 'read', 'dnf']))
        && (!('rating' in data) || (data.rating is number))
        && (!('liked' in data) || (data.liked is bool))
        && (!('notes' in data) || (data.notes is string))
        && (!('coverUrl' in data) || (data.coverUrl is string))
        && (!('backCoverUrl' in data) || (data.backCoverUrl is string))
        && (!('genre' in data) || (data.genre is string))
        && (!('series' in data) || (data.series is string))
        && (!('seriesPosition' in data) || (data.seriesPosition is string))
        && (!('isbn' in data) || (data.isbn is string))
        && (!('pages' in data) || (data.pages is number))
        && (!('boredomReason' in data) || (data.boredomReason is string))
        // Relaxed updatedAt check
        && (!('updatedAt' in data) || data.updatedAt <= request.time);
    }

    match /books/{bookId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid;
        
      allow delete: if isSignedIn();
    }

    // --- Author Validations ---
    function isValidAuthor(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt'])
        && data.keys().size() <= 6
        && data.name is string && data.name.size() <= 256
        && (!('liked' in data) || data.liked is bool)
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000))
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    function isValidAuthorUpdate(data) {
      return (!('name' in data) || (data.name is string && data.name.size() <= 256))
        && (!('liked' in data) || data.liked is bool)
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000));
    }

    match /authors/{authorId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidAuthor(incoming());
      
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid
        && isValidAuthorUpdate(incoming())
        && incoming().userId == resource.data.userId;
        
      allow delete: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
